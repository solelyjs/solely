{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Solely Template",
    "scopeName": "text.html.solely",
    "injectionSelector": "L:text.html.derivative",
    "patterns": [
        {
            "name": "meta.embedded.solely.expression",
            "begin": "\\{\\{",
            "end": "\\}\\}",
            "beginCaptures": {
                "0": {
                    "name": "punctuation.definition.template-expression.begin.solely"
                }
            },
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.template-expression.end.solely"
                }
            },
            "patterns": [
                {
                    "name": "keyword.other.solely.data",
                    "match": "\\$data\\b"
                },
                {
                    "name": "variable.language.solely.this",
                    "match": "\\bthis\\b"
                },
                {
                    "name": "variable.other.property",
                    "match": "(?<=\\$data\\.)(\\w+)"
                },
                {
                    "name": "entity.name.function",
                    "match": "(?<=\\.)(\\w+)(?=\\s*\\()"
                }
            ]
        },
        {
            "name": "meta.tag.solely.control",
            "match": "<\\/?(If|ElseIf|Else|For)\\b",
            "captures": {
                "1": {
                    "name": "keyword.control.solely"
                }
            }
        },
        {
            "name": "meta.attribute.solely.event",
            "match": "@(\\w+(?:-\\w+)*)\\s*=\\s*\"([^\"]*)\"",
            "captures": {
                "1": {
                    "name": "entity.other.attribute-name.event.solely"
                },
                "2": {
                    "name": "meta.embedded.solely.event-value",
                    "patterns": [
                        {
                            "name": "variable.language.solely.this",
                            "match": "\\bthis\\b"
                        },
                        {
                            "name": "entity.name.function",
                            "match": "(?<=\\.)(\\w+)(?=\\s*\\()"
                        },
                        {
                            "name": "variable.parameter.solely",
                            "match": "\\bevent\\b"
                        },
                        {
                            "name": "variable.parameter.solely",
                            "match": "\\bel\\b"
                        },
                        {
                            "name": "keyword.other.solely.data",
                            "match": "\\$data\\b"
                        },
                        {
                            "name": "variable.other.property",
                            "match": "(?<=\\$data\\.)(\\w+)"
                        }
                    ]
                }
            }
        },
        {
            "name": "meta.attribute.solely.html-event",
            "match": "\\bon(click|change|input|keydown|keyup|keypress|submit|focus|blur|dblclick|mouseenter|mouseleave|mouseover|mouseout|mousedown|mouseup|scroll|resize|drag|dragstart|dragend|dragover|dragenter|dragleave|drop|contextmenu|wheel|load|error|invalid|reset|select)\\s*=\\s*\"([^\"]*)\"",
            "captures": {
                "0": {
                    "name": "entity.other.attribute-name.html-event.solely"
