        {
            "name": "meta.attribute.solely.s-boolean",
            "match": "s-(visible|disabled|checked|readonly|required|hidden|selected)\\s*=\\s*\"([^\"]*)\"",
            "captures": {
                "1": {
                    "name": "entity.other.attribute-name.s-boolean.solely"
