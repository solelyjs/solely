                    "name": "variable.other.constant"
                }
            }
        },
        {
            "name": "meta.attribute.solely.slot-name",
            "match": "\\bname\\s*=\\s*\"([^\"]*)\"",
            "captures": {
                "1": {
                    "name": "string.quoted.double"
                }
            }
        },
        {
            "name": "meta.attribute.solely.bind-name",
            "match": ":name\\s*=\\s*\"([^\"]*)\"",
